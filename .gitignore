# Build output
/swartznet
/swartznet.exe
/build/

# `dist/` is the cross-compile output directory used by
# scripts/build-release.sh — full of multi-MB binaries that we
# upload to GitHub Releases instead of checking in.
/dist/

# Go
*.test
*.out
/vendor/
coverage.txt
coverage.html

# Runtime data (downloaded torrents, local index, logs)
/data/
/var/
*.log

# Upstream research clones — not part of this repo. The five reports in docs/
# are the canonical written output of that research; the full clones are kept
# locally only.
/research/

# Editor / OS noise
.vscode/
.idea/
*.swp
*~
.DS_Store
Thumbs.db

# tests/torrent-test/ run artifacts. `source/` is regenerated by
# scripts/gen-test-fixture.sh and the per-daemon state dirs are
# populated by scripts/test-multi-peer.sh. None of it belongs in
# git — the scripts produce it deterministically on demand.
/tests/torrent-test/source/
/tests/torrent-test/seeder-data/
/tests/torrent-test/seeder-index/
/tests/torrent-test/peer*-data/
/tests/torrent-test/peer*-index/
/tests/torrent-test/results/
